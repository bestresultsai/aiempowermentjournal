# ---------------------------------------------------------------------------
# BestResults.AI Platform — environment variable template.
#
# Copy this file to .env.local for local development. .env.local is
# gitignored — never commit secrets.
#
# In production / staging, set these on Netlify per branch (see
# docs/deployment-kickoff.md §5).
#
# Every var consumed by the browser bundle MUST be prefixed with VITE_.
# Anything without VITE_ is server-side only (for Netlify Functions in
# Phase 3).
# ---------------------------------------------------------------------------

# Identifies which environment this build is running in. Shown in the admin
# diagnostics panel and stamped on every Supabase request via the
# `x-brai-env` header.
VITE_ENV_NAME=development

# Git SHA of the build. Netlify sets this via the COMMIT_REF build-time
# variable, but you can override locally if you're testing release tagging.
VITE_GIT_SHA=dev

# ---------------------------------------------------------------------------
# Supabase — auth + database + storage.
# Without these, the platform stays on the localStorage demo backend.
# ---------------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Sentry — error reporting.
# When VITE_SENTRY_DSN is set, src/lib/observability.js loads @sentry/react
# at runtime and starts capturing errors.
# ---------------------------------------------------------------------------

VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# PostHog — product analytics.
# When VITE_POSTHOG_KEY is set, src/lib/observability.js loads posthog-js at
# runtime and starts capturing page views + key events.
# ---------------------------------------------------------------------------

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Resend — transactional email.
# This key is server-side only — it's read by a Netlify Function in Phase 3,
# never by the browser bundle. Set it on Netlify without the VITE_ prefix.
# Listed here so devs know the key exists; do not reference from app code.
# ---------------------------------------------------------------------------

# RESEND_API_KEY=
# RESEND_FROM_EMAIL=hello@tools.bestresults.ai

# ---------------------------------------------------------------------------
# Seed script — service-role key.
# Used only by scripts/seed-staging.mjs. NEVER expose to the browser.
# ---------------------------------------------------------------------------

# SUPABASE_SERVICE_ROLE_KEY=
